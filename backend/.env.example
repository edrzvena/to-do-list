# Copy file ini jadi `.env` lalu isi nilainya:  cp .env.example .env

# ===== Server =====
PORT=3000

# ===== Auth / JWT =====
# Kunci rahasia buat nge-sign token. Isi string acak yang panjang & susah ditebak.
JWT_SECRET=ganti_dengan_string_acak_panjang
JWT_EXPIRES_IN=7d

# ===== PostgreSQL Database =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=todo_list

# Alternatif: connection string sekaligus
# DATABASE_URL=postgresql://user:password@localhost:5432/todo_list
